# App
HOST=http://localhost:3000
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Database
DATABASE_URL="file:./dev.sqlite"

# Shopify Partner app (OAuth + Admin API)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_products,read_products,write_files,read_files

# Image compositing
AWS_LAMBDA_COMPOSITE_URL=

# S3 (public URLs preferred for Shopify media)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-1
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_ACL=public-read

LOCAL_RESULTS_DIR=./storage/results
PUBLIC_RESULTS_BASE_URL=

POD_COMPOSE_CONCURRENCY=6
POD_SYNC_CONCURRENCY=5
