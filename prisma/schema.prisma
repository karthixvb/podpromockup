generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shops ShopConnection[]
}

model ShopConnection {
  id          String   @id @default(cuid())
  userId      String
  shop        String
  accessToken String
  scope       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shop])
  @@index([shop])
}

model ShopSettings {
  id                   String   @id @default(cuid())
  shop                 String   @unique
  vendor               String   @default("MyStore")
  defaultSizes         String   @default("[\"S\",\"M\",\"L\",\"XL\",\"2XL\",\"3XL\"]")
  storagePrefix        String?
  compareAtPercent     Float    @default(0)
  defaultProductStatus String   @default("ACTIVE")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Template {
  id              String   @id @default(cuid())
  shop            String
  name            String
  description     String?
  productType     String
  category        String   @default("unisex")
  sortOrder       Int      @default(0)
  thumbnailUrl    String?
  basePrice       Float    @default(19.99)
  pricingConfigId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pricingConfig PricingConfig?       @relation(fields: [pricingConfigId], references: [id], onDelete: SetNull)
  variants      Variant[]
  setMembers    TemplateSetMember[]
  batchItems    BatchItem[]
  productLinks  ShopifyProductLink[]

  @@index([shop])
  @@index([shop, productType])
}

model Variant {
  id         String   @id @default(cuid())
  templateId String
  name       String
  colorHex   String   @default("#FFFFFF")
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template   Template       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  scenes     VariantScene[]
  batchItems BatchItem[]

  @@index([templateId])
}

model VariantScene {
  id            String   @id @default(cuid())
  variantId     String
  name          String   @default("Main")
  imageUrl      String?
  cropRegion    String   @default("{\"x\":50,\"y\":50,\"width\":200,\"height\":250}")
  useLightImage Boolean  @default(true)
  useDarkImage  Boolean  @default(true)
  sortOrder     Int      @default(0)
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  variant    Variant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  batchItems BatchItem[]

  @@index([variantId])
}

model TemplateSet {
  id          String   @id @default(cuid())
  shop        String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   TemplateSetMember[]
  batchJobs BatchJob[]

  @@index([shop])
}

model TemplateSetMember {
  id            String @id @default(cuid())
  templateSetId String
  templateId    String
  sortOrder     Int    @default(0)

  templateSet TemplateSet @relation(fields: [templateSetId], references: [id], onDelete: Cascade)
  template    Template    @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateSetId, templateId])
}

model PricingConfig {
  id               String   @id @default(cuid())
  shop             String
  name             String
  basePrice        Float    @default(19.99)
  sizeAdjustments  String   @default("[]")
  colorAdjustments String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  templates Template[]
  batchJobs BatchJob[]

  @@index([shop])
}

model BatchJob {
  id                 String   @id @default(cuid())
  shop               String
  name               String
  templateSetId      String?
  pricingConfigId    String?
  status             String   @default("pending")
  shopifySyncStatus  String   @default("idle")
  autoPublishShopify Boolean  @default(true)
  createAsDraft      Boolean  @default(false)
  totalItems         Int      @default(0)
  processedItems     Int      @default(0)
  failedItems        Int      @default(0)
  errorMessage       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  templateSet   TemplateSet?         @relation(fields: [templateSetId], references: [id], onDelete: SetNull)
  pricingConfig PricingConfig?       @relation(fields: [pricingConfigId], references: [id], onDelete: SetNull)
  items         BatchItem[]
  productLinks  ShopifyProductLink[]

  @@index([shop])
  @@index([status])
}

model BatchItem {
  id               String   @id @default(cuid())
  jobId            String
  templateId       String?
  variantId        String?
  sceneId          String?
  sceneName        String?
  sku              String
  title            String
  description      String?
  tags             String   @default("[]")
  designUrl        String
  imageType        String   @default("auto")
  resultUrl        String?
  status           String   @default("pending")
  errorMessage     String?
  shopifyProductId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job      BatchJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  template Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  variant  Variant?      @relation(fields: [variantId], references: [id], onDelete: SetNull)
  scene    VariantScene? @relation(fields: [sceneId], references: [id], onDelete: SetNull)

  @@index([jobId, status])
  @@index([sku])
}

model ShopifyProductLink {
  id                String   @id @default(cuid())
  shop              String
  batchJobId        String?
  templateId        String?
  designSku         String
  groupId           String
  productTypeKey    String
  category          String?
  shopifyProductGid String
  shopifyHandle     String?
  thumbnailUrl      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  batchJob BatchJob? @relation(fields: [batchJobId], references: [id], onDelete: SetNull)
  template Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([shop, designSku, productTypeKey])
  @@index([shop, groupId])
}
